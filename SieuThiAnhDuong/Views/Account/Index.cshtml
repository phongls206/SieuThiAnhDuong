@model SieuThiAnhDuong.Models.NhanVien

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4">
                <h5 class="text-primary fw-bold mb-4">
                    <i class="bi bi-person-vcard"></i> Thông tin tài khoản
                </h5>
                <div class="row mb-3 border-bottom pb-2">
                    <div class="col-sm-4 text-muted">Họ và tên:</div>
                    <div class="col-sm-8 fw-bold">@Model.HoTen</div>
                </div>
                <div class="row mb-3 border-bottom pb-2">
                    <div class="col-sm-4 text-muted">Chức vụ:</div>
                    <div class="col-sm-8">
                        <span class="badge bg-info">@Model.ChucVu</span>
                    </div>
                </div>
                <div class="row mb-3 border-bottom pb-2">
                    <div class="col-sm-4 text-muted">Số điện thoại:</div>
                    <div class="col-sm-8">@Model.SoDT</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Địa chỉ:</div>
                    <div class="col-sm-8">@Model.DiaChi</div>
                </div>
                
            </div>
        </div>

        <div class="col-md-4 text-center">
            <div class="card shadow-sm border-0 p-5 h-100">
                <img src="https://ui-avatars.com/api/?name=@Model.HoTen&background=random"
                     class="rounded-circle img-thumbnail mx-auto mb-3" style="width: 120px;">
                <h5 class="fw-bold">@Model.HoTen</h5>
             
            </div>
        </div>
    </div>
</div>