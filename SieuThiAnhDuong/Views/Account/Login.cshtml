@model SieuThiAnhDuong.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Siêu thị Ánh Dương</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { 
            --primary-blue: #007bff; 
            --dark-blue: #0056b3;
            --glass-bg: rgba(255, 255, 255, 0.95);
        }

        body { 
            background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
            height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            overflow: hidden; 
            position: relative;
        }

        body::before, body::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: linear-gradient(135deg, rgba(0,123,255,0.1), rgba(0,86,179,0.05));
            z-index: -1;
        }
        body::before { top: -50px; left: -50px; }
        body::after { bottom: -50px; right: -50px; }

        .login-container {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 950px;
            display: flex;
            min-height: 550px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            border: 1px solid rgba(255,255,255,0.8);
        }

        .login-container:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.12);
        }

        .login-sidebar { 
            background: linear-gradient(135deg, #007bff, #0056b3); 
            color: white; 
            padding: 45px; 
            width: 42%; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            position: relative;
        }

        .intro-box {
            position: relative;
            height: 140px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            margin-bottom: 25px;
        }

        #cartIcon {
            position: absolute;
            left: 0;
            top: 20px;
            animation: cartMove 2.2s cubic-bezier(0.45, 0.05, 0.55, 0.95) forwards;
        }

        @@keyframes cartMove {
            0% { transform: translateX(-50px); opacity: 0; }
            20% { opacity: 1; }
            70% { transform: translateX(150px); opacity: 1; }
            100% { transform: translateX(250px); opacity: 0; }
        }

        #logoText {
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.8s ease-out;
        }

        #logoText.active {
            opacity: 1;
            transform: translateY(0);
        }

        .static-cart { font-size: 2.5rem; margin-bottom: 10px; display: block; color: #fff; }
        .login-sidebar h2 { font-weight: 800; font-size: 2.2rem; margin: 0; line-height: 1.2; }

        .login-sidebar .feature-item { 
            display: flex; 
            align-items: center; 
            margin-bottom: 18px; 
            font-size: 0.95rem; 
            background: rgba(255,255,255,0.1);
            padding: 10px 15px;
            border-radius: 10px;
            transition: 0.3s;
        }
        .login-sidebar .feature-item:hover { background: rgba(255,255,255,0.2); transform: translateX(5px); }
        .login-sidebar .feature-item i { margin-right: 12px; color: #51cf66; font-size: 1.1rem; }

        .login-form-section { 
            padding: 60px; 
            width: 58%; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            background-color: #fff;
        }

        .login-form-section h3 { font-weight: 800; color: #1a1a1a; margin-bottom: 8px; font-size: 1.8rem; }
        .login-form-section p { color: #888; margin-bottom: 35px; font-size: 0.95rem; }
        
        .form-label { color: #444; letter-spacing: 0.5px; }
        
        /* Cấu trúc Input Group cố định độ cao để icon cân xứng */
        .input-group { 
            border-radius: 10px; 
            overflow: hidden; 
            transition: 0.3s; 
            border: 1px solid #e1e1e1; 
            background: #f8f9fa;
        }

        .form-control { 
            border: none;
            padding: 14px 18px; 
            font-size: 0.95rem;
            background: #fff !important; /* Giữ nền trắng cho ô nhập */
        }
        .form-control:focus { box-shadow: none; }
        
        .input-group-text { 
            background: #f8f9fa; 
            border: none;
            color: #888; 
            padding-left: 18px;
            display: flex;
            align-items: center;
        }

        /* Nút ẩn hiện mật khẩu - CĂN GIỮA TUYỆT ĐỐI */
        .password-toggle {
            background: #fff; /* Để cùng màu với input cho đẹp */
            border: none;
            color: #888;
            padding: 0 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
            outline: none;
        }
        .password-toggle:hover { color: var(--primary-blue); }
        .password-toggle i { font-size: 1.2rem; line-height: 1; }

        .input-group:focus-within { 
            box-shadow: 0 5px 15px rgba(0,123,255,0.1); 
            border-color: var(--primary-blue); 
        }

        .btn-login { 
            background: linear-gradient(to right, #007bff, #0056b3); 
            color: white; 
            border: none; 
            padding: 14px; 
            border-radius: 10px; 
            font-weight: 700; 
            font-size: 1rem;
            transition: 0.4s; 
            width: 100%; 
            margin-top: 25px; 
            box-shadow: 0 5px 15px rgba(0,123,255,0.3);
        }

        .btn-login:hover { 
            transform: translateY(-3px); 
            box-shadow: 0 8px 20px rgba(0,123,255,0.4);
            filter: brightness(1.1);
        }
        
        .footer-text { font-size: 0.85rem; color: #aaa; margin-top: 50px; text-align: center; }
        .footer-text strong { color: #555; }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-sidebar">
            <div class="intro-box">
                <div id="cartIcon">
                    <i class="bi bi-cart-fill" style="font-size: 4rem; filter: drop-shadow(0 5px 10px rgba(0,0,0,0.2));"></i>
                </div>
                
                <div id="logoText">
                    <i class="bi bi-cart-fill static-cart"></i>
                    <h2>Siêu Thị<br>Ánh Dương</h2>
                </div>
            </div>
            
            <p class="mb-4" style="opacity: 0.9; font-weight: 300;">Phần mềm quản lý bán hàng thông minh, tối ưu hóa quy trình vận hành siêu thị.</p>
            
            <div class="feature-list">
                <div class="feature-item"><i class="bi bi-shield-check"></i> Quản lý mặt hàng hiệu quả</div>
                <div class="feature-item"><i class="bi bi-lightning-charge"></i> Xử lý giao dịch nhanh chóng</div>
                <div class="feature-item"><i class="bi bi-graph-up-arrow"></i> Thống kê doanh thu chính xác</div>
            </div>
        </div>

        <div class="login-form-section">
            <h3>Chào mừng trở lại!</h3>
            <p>Vui lòng đăng nhập để bắt đầu phiên làm việc.</p>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Tên đăng nhập</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person-circle"></i></span>
                        <input asp-for="Username" class="form-control" placeholder="Nhập tài khoản của bạn" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label small fw-bold">Mật khẩu</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Password" type="password" id="passwordInput" class="form-control" placeholder="Nhập mật khẩu" required />
                        <button type="button" class="password-toggle" id="togglePassword">
                            <i class="bi bi-eye-slash" id="eyeIcon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    XÁC NHẬN ĐĂNG NHẬP <i class="bi bi-chevron-right ms-2" style="font-size: 0.8rem;"></i>
                </button>
            </form>

            <div class="footer-text">
                Hỗ trợ kỹ thuật: <strong>0787.304.341</strong> (24/7)<br />
                <span style="font-size: 0.75rem; margin-top: 5px; display: block;">© 2026 Ánh Dương Mart - All Rights Reserved</span>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Animation Logo
            const cart = document.getElementById('cartIcon');
            const logo = document.getElementById('logoText');
            if(cart && logo) {
                cart.addEventListener('animationend', function() {
                    cart.style.display = 'none'; 
                    logo.classList.add('active'); 
                });
            }

            // Xử lý ẩn/hiện mật khẩu
            const togglePassword = document.querySelector('#togglePassword');
            const password = document.querySelector('#passwordInput');
            const eyeIcon = document.querySelector('#eyeIcon');

            if(togglePassword) {
                togglePassword.addEventListener('click', function () {
                    // Chuyển đổi type
                    const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
                    password.setAttribute('type', type);
                    
                    // Chuyển đổi icon
                    eyeIcon.classList.toggle('bi-eye');
                    eyeIcon.classList.toggle('bi-eye-slash');
                });
            }
        });
    </script>
</body>
</html>