@model IEnumerable<SieuThiAnhDuong.Models.TaiKhoan>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-person-circle"></i> Quản lý tài khoản</h3>
        <button class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#createAccountModal">
            <i class="bi bi-plus-circle"></i> Cấp tài khoản mới
        </button>
    </div>

    @* Hiển thị thông báo từ Controller *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tên đăng nhập</th>
                            <th>Nhân viên sở hữu</th>
                            <th>Quyền truy cập</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.TenDangNhap</td>
                                <td>
                                    <span class="text-muted">#@item.MaNV</span> -
                                    <span class="fw-semibold">@(item.NhanVien?.HoTen ?? "N/A")</span>
                                </td>
                                <td>
                                    @if (item.Quyen == "Admin")
                                    {
                                        <span class="badge bg-danger text-uppercase">Admin</span>
                                    }
                                    else if (item.Quyen == "Thủ kho")
                                    {
                                        <span class="badge bg-info text-dark text-uppercase">Thủ kho</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary text-uppercase">Nhân viên</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        @* Form Reset Mật khẩu *@
                                        <form asp-action="ResetPassword" method="post" class="confirm-reset">
                                            <input type="hidden" name="id" value="@item.TenDangNhap" />
                                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Đặt lại mật khẩu">
                                                <i class="bi bi-key-fill"></i>
                                            </button>
                                        </form>

                                        @* Form Xóa tài khoản (Trừ admin gốc) *@
                                        @if (item.TenDangNhap.ToLower() != "admin")
                                        {
                                            <form asp-action="Delete" method="post" class="confirm-delete">
                                                <input type="hidden" name="id" value="@item.TenDangNhap" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa tài khoản">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" disabled title="Tài khoản hệ thống">
                                                <i class="bi bi-shield-lock-fill"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* MODAL CẤP TÀI KHOẢN *@
<div class="modal fade" id="createAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Cấp tài khoản mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn nhân viên chưa có tài khoản</label>
                        @* Sử dụng ViewBag.MaNV từ Controller *@
                        <select name="MaNV" class="form-select shadow-sm" asp-items="ViewBag.MaNV" required>
                            <option value="">-- Chọn nhân viên --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập</label>
                        <input type="text" name="TenDangNhap" class="form-control shadow-sm" placeholder="VD: van_a" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu khởi tạo</label>
                        <input type="text" name="MatKhau" class="form-control bg-light" value="123456" required />
                        <small class="text-muted italic">* Bạn có thể thay đổi hoặc để mặc định 123456</small>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success px-4 fw-bold">Xác nhận cấp</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
        // Xác nhận Reset Password
        $('.confirm-reset').on('submit', function (e) {
        e.preventDefault();
        var form = this;
        Swal.fire({
        title: 'Reset mật khẩu?',
        text: "Tài khoản sẽ được đặt lại về mật khẩu mặc định '123456'!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ffc107',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Đồng ý',
        cancelButtonText: 'Hủy',
        reverseButtons: true
        }).then((result) => { if (result.isConfirmed) form.submit(); });
        });

        // Xác nhận Xóa tài khoản
        $('.confirm-delete').on('submit', function (e) {
        e.preventDefault();
        var form = this;
        Swal.fire({
        title: 'Xóa tài khoản này?',
        text: "Hành động này sẽ xóa vĩnh viễn quyền truy cập của người dùng!",
        icon: 'error',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Xác nhận xóa',
        cancelButtonText: 'Hủy',
        reverseButtons: true
        }).then((result) => { if (result.isConfirmed) form.submit(); });
        });
        });
    </script>
}