@model IEnumerable<SieuThiAnhDuong.Models.TaiKhoan>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-person-circle"></i> Danh sách tài khoản</h3>
        <button class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#createAccountModal">
            <i class="bi bi-plus-circle"></i> Cấp tài khoản mới
        </button>
    </div>

    @* Thông báo thành công/lỗi *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên đăng nhập</th>
                        <th>Chủ sở hữu (Mã NV)</th>
                        <th>Quyền hạn</th>
                    
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.TenDangNhap</td>
                            <td>
                                <span class="text-muted">#@item.MaNV</span> -
                                <span class="fw-semibold">@(item.NhanVien?.HoTen ?? "N/A")</span>
                            </td>
                            <td>
                                @if (item.NhanVien?.ChucVu == "Admin")
                                {
                                    <span class="badge bg-danger text-uppercase" style="font-size: 0.75rem;">Admin</span>
                                }
                                else if (item.NhanVien?.ChucVu == "Thủ kho")
                                {
                                    <span class="badge bg-info text-dark text-uppercase" style="font-size: 0.75rem;">Thủ kho</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary text-uppercase" style="font-size: 0.75rem;">Nhân viên</span>
                                }
                            </td>
                          
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @* Nút Reset mật khẩu *@
                                    <form asp-action="ResetPassword" method="post" onsubmit="return confirm('Reset mật khẩu tài khoản này về 123456?')">
                                        <input type="hidden" name="id" value="@item.TenDangNhap" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Reset mật khẩu">
                                            <i class="bi bi-key-fill"></i>
                                        </button>
                                    </form>

                                    @* Nút Xóa (Chặn xóa tài khoản admin hệ thống) *@
                                    @if (item.TenDangNhap.ToLower() != "admin")
                                    {
                                        <form asp-action="Delete" method="post" onsubmit="return confirm('Xác nhận xóa tài khoản này? Thao tác này không thể hoàn tác!')">
                                            <input type="hidden" name="id" value="@item.TenDangNhap" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa tài khoản">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Bảo vệ hệ thống: Không thể xóa Admin">
                                            <i class="bi bi-shield-lock-fill"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal Cấp tài khoản mới *@
<div class="modal fade" id="createAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Cấp tài khoản mới</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small text-uppercase">1. Chọn nhân viên chưa có tài khoản</label>
                        @* asp-items="ViewBag.MaNV" sẽ nhận danh sách đã lọc từ Controller *@
                        <select name="MaNV" class="form-select border-primary-subtle" asp-items="ViewBag.MaNV" required>
                            <option value="">-- Chọn nhân viên --</option>
                        </select>
                        <div class="form-text mt-1 italic small text-muted">* Chỉ hiện nhân viên chưa có tài khoản hệ thống.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small text-uppercase">2. Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input name="TenDangNhap" class="form-control" placeholder="Ví dụ: nhanvien_a" required maxlength="50" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small text-uppercase">3. Mật khẩu khởi tạo</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input name="MatKhau" type="password" class="form-control" placeholder="Nhập mật khẩu" required minlength="6" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-success px-4 shadow-sm">
                        <i class="bi bi-check-lg me-1"></i> Lưu tài khoản
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>