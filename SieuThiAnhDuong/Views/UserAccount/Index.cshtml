@model IEnumerable<SieuThiAnhDuong.Models.TaiKhoan>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-person-circle"></i> Danh sách tài khoản</h3>
        <button class="btn btn-success shadow-sm" data-bs-toggle="modal" data-bs-target="#createAccountModal">
            <i class="bi bi-plus-circle"></i> Cấp tài khoản mới
        </button>
    </div>

    @* Lưu ý: Phần TempData thông báo ở đây có thể giữ lại hoặc bỏ vì mình đã có Toast ở Layout *@

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên đăng nhập</th>
                        <th>Chủ sở hữu (Mã NV)</th>
                        <th>Quyền hạn</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-dark">@item.TenDangNhap</td>
                            <td>
                                <span class="text-muted">#@item.MaNV</span> -
                                <span class="fw-semibold">@(item.NhanVien?.HoTen ?? "N/A")</span>
                            </td>
                            <td>
                                @if (item.NhanVien?.ChucVu == "Admin")
                                {
                                    <span class="badge bg-danger text-uppercase" style="font-size: 0.75rem;">Admin</span>
                                }
                                else if (item.NhanVien?.ChucVu == "Thủ kho")
                                {
                                    <span class="badge bg-info text-dark text-uppercase" style="font-size: 0.75rem;">Thủ kho</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary text-uppercase" style="font-size: 0.75rem;">Nhân viên</span>
                                }
                            </td>
                          
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    @* SỬA Ở ĐÂY: Thêm class confirm-reset *@
                                    <form asp-action="ResetPassword" method="post" class="confirm-reset">
                                        <input type="hidden" name="id" value="@item.TenDangNhap" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning" title="Reset mật khẩu">
                                            <i class="bi bi-key-fill"></i>
                                        </button>
                                    </form>

                                    @if (item.TenDangNhap.ToLower() != "admin")
                                    {
                                        @* SỬA Ở ĐÂY: Thêm class confirm-delete *@
                                        <form asp-action="Delete" method="post" class="confirm-delete">
                                            <input type="hidden" name="id" value="@item.TenDangNhap" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa tài khoản">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Bảo vệ hệ thống: Không thể xóa Admin">
                                            <i class="bi bi-shield-lock-fill"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ... Giữ nguyên phần Modal ... *@

@section Scripts {
    <script>
        $(document).ready(function () {
            // 1. Xử lý Reset Mật Khẩu
            $('.confirm-reset').on('submit', function (e) {
                e.preventDefault(); // Chặn submit form ngay lập tức
                var form = this;

                Swal.fire({
                    title: 'Reset mật khẩu?',
                    text: "Tài khoản này sẽ được đặt lại mật khẩu về '123456'!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ffc107',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Đồng ý Reset',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit(); // Thực hiện gửi form đi
                    }
                });
            });

            // 2. Xử lý Xóa Tài Khoản
            $('.confirm-delete').on('submit', function (e) {
                e.preventDefault();
                var form = this;

                Swal.fire({
                    title: 'Xóa tài khoản này?',
                    text: "Thao tác này sẽ xóa vĩnh viễn và không thể hoàn tác!",
                    icon: 'error',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Xác nhận xóa',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}