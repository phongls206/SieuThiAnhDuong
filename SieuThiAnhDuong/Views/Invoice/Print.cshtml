@model SieuThiAnhDuong.Models.HoaDon

@{
    ViewData["Title"] = "In Hóa Đơn";
    Layout = null;
}<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>In Hóa Đơn #@Model.MaHD</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        html, body { height: 100%; margin: 0; }

        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #e9ecef; 
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            align-items: center;     
            padding: 20px 0; /* Thêm padding để không bị dính mép màn hình */
        }

        .ticket { 
            width: 80mm; 
            background: white; 
            padding: 15px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.1); 
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            max-height: 80vh; /* Giới hạn hóa đơn cao tối đa 80% màn hình */
        }

        /* --- PHẦN QUAN TRỌNG: TẠO THANH CUỘN CHO DANH SÁCH SẢN PHẨM --- */
        .product-scroll {
            overflow-y: auto;
            flex: 1; /* Tự động co giãn */
            margin: 10px 0;
            padding-right: 5px;
        }
        /* Tùy chỉnh thanh cuộn cho nhỏ gọn đẹp mắt */
        .product-scroll::-webkit-scrollbar { width: 4px; }
        .product-scroll::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 10px; }

        .centered { text-align: center; }
        .logo-text { color: #00bfff; letter-spacing: 1px; }
        
        table { width: 100%; border-collapse: collapse; }
        td, th { padding: 6px 0; border-bottom: 1px dashed #dee2e6; font-size: 13px; }
        th { color: #495057; text-transform: uppercase; font-size: 11px; position: sticky; top: 0; background: white; z-index: 1; }
        
        .total-section { border-top: 2px solid #333; padding-top: 10px; }
        .total { font-weight: bold; font-size: 16px; display: flex; justify-content: space-between; }
        .info-row { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 3px; }
        .divider { border-top: 2px solid #333; margin: 10px 0; }

        .action-buttons { width: 80mm; margin-top: 15px; }

        @@media print {
            body { background: white; display: block; padding: 0; }
            .ticket { width: 100%; max-height: none; box-shadow: none; border: none; margin: 0; padding: 0; display: block; }
            .product-scroll { overflow: visible; max-height: none; }
            .d-print-none { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="ticket">
        <div class="centered">
            <h4 class="fw-bold mb-0 logo-text">SIÊU THỊ ÁNH DƯƠNG</h4>
            <p style="font-size: 11px; color: #6c757d;">
                Tổ 1 P.Tân Thịnh, TPTN <br>
                Hotline: 0787.304.341
            </p>
        </div>

        <div class="divider"></div>

        <div class="mb-1">
            <div class="info-row"><span>Mã hóa đơn:</span><strong>#@Model.MaHD</strong></div>
            <div class="info-row"><span>Ngày lập:</span><span>@Model.NgayLap.ToString("dd/MM/yyyy")</span></div>
            <div class="info-row"><span>Giờ xuất:</span><strong>@Model.NgayLap.ToString("HH:mm:ss")</strong></div>
            <div class="info-row"><span>Thu ngân:</span><span>@Model.NhanVien?.HoTen</span></div>
        </div>

        <div class="product-scroll">
            <table>
                <thead>
                    <tr>
                        <th class="text-start">Sản phẩm</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">T.Tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ChiTietHoaDons)
                    {
                        <tr>
                            <td class="text-start">
                                @item.SanPham?.TenSP <br>
                                <small class="text-muted">@item.DonGia.ToString("N0")</small>
                            </td>
                            <td class="text-center">@item.SoLuong</td>
                            <td class="text-end">@((item.SoLuong * item.DonGia).ToString("N0"))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="total-section">
            <div class="total">
                <span>TỔNG CỘNG</span>
                <span class="text-danger">@Model.TongTien.ToString("N0")</span>
            </div>
            <div class="mt-2" style="font-size: 12px;">
                Phương Thức: <strong>@Model.PhuongThucThanhToan</strong>
            </div>
        </div>

        <div class="centered mt-3">
            <p style="font-size: 11px; font-style: italic; margin-bottom: 0;">
                Cảm ơn Quý khách! Hẹn gặp lại!
            </p>
        </div>
    </div>

    <div class="action-buttons d-print-none">
        <button onclick="window.print()" class="btn btn-primary w-100 py-2 fw-bold mb-2 shadow-sm">
            <i class="bi bi-printer-fill me-2"></i>XÁC NHẬN IN HÓA ĐƠN
        </button>
        <a href="/Invoice/Create" class="btn btn-light w-100 border text-secondary">
            <i class="bi bi-arrow-left me-2"></i>Quay lại bán hàng
        </a>
    </div>
</body>
</html>