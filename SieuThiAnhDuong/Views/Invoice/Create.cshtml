@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    ViewData["Title"] = "Lập hóa đơn bán hàng";
}

<div class="container-fluid mt-4">
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-card-checklist me-2"></i>Danh mục mặt hàng</h4>
                        <div class="input-group shadow-sm" style="max-width: 350px;">
                            <span class="input-group-text bg-white border-primary text-primary"><i class="bi bi-search"></i></span>
                            <input type="text" id="searchProduct" class="form-control border-primary" placeholder="Tìm tên sản phẩm nhanh...">
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Sản phẩm</th>
                                    <th>Giá bán</th>
                                    <th class="text-center">Tồn kho</th>
                                    <th style="width: 140px;">Số lượng</th>
                                    <th class="text-end pe-3">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="productList">
                                @foreach (var p in ViewBag.Products)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-dark">@p.TenSP</td>
                                        <td class="text-danger fw-bold">@p.GiaBan.ToString("N0") đ</td>
                                        <td class="text-center">
                                            @if (p.SoLuongTon <= 0)
                                            {
                                                <span class="badge bg-danger shadow-sm py-2 px-3 w-75">Hết hàng</span>
                                            }
                                            else if (p.SoLuongTon < 10)
                                            {
                                                <span class="badge bg-warning text-dark shadow-sm py-2 px-3 w-75">Sắp hết (@p.SoLuongTon)</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success shadow-sm py-2 px-3 w-75">Còn (@p.SoLuongTon)</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="input-group input-group-sm px-2">
                                                <input type="number" id="qty-@p.MaSP"
                                                       value="@(p.SoLuongTon > 0 ? 1 : 0)"
                                                       min="0"
                                                       max="@p.SoLuongTon"
                                                       oninput="checkQty(@p.MaSP, @p.SoLuongTon)"
                                                       class="form-control text-center fw-bold border-primary"
                                                @(p.SoLuongTon <= 0 ? "disabled" : "") />
                                            </div>
                                        </td>
                                        <td class="text-end pe-3">
                                            <button id="btn-add-@p.MaSP"
                                                    onclick="addToCart(@p.MaSP, '@p.TenSP', @p.GiaBan, @p.SoLuongTon)"
                                                    class="btn @(p.SoLuongTon > 0 ? "btn-primary" : "btn-secondary") btn-sm px-3 shadow-sm"
                                                @(p.SoLuongTon <= 0 ? "disabled" : "")>
                                                <i class="bi bi-plus-lg"></i> Thêm
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 overflow-hidden">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-cart3 me-2"></i>Giỏ hàng</h4>
                </div>
                <div class="card-body">
                    <ul id="cart" class="list-group list-group-flush mb-3" style="min-height: 150px; max-height: 400px; overflow-y: auto;">
                        <li class="text-muted text-center py-5">
                            <i class="bi bi-cart-x display-4 d-block mb-2 opacity-25"></i>
                            Chưa có sản phẩm nào
                        </li>
                    </ul>
                    <hr class="border-secondary opacity-25">

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark"><i class="bi bi-credit-card-2-back me-1"></i> Phương thức thanh toán:</label>
                        <select id="phuongThucThanhToan" class="form-select border-success shadow-sm">
                            <option value="Tiền mặt">💵 Tiền mặt</option>
                            <option value="Chuyển khoản">💳 Chuyển khoản</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded-3 shadow-sm border">
                        <span class="h5 mb-0 fw-bold">Tổng cộng:</span>
                        <span class="h3 mb-0 text-danger fw-bold"><span id="totalAmount">0</span> đ</span>
                    </div>

                    <button onclick="finishOrder()" class="btn btn-success w-100 py-3 fw-bold shadow-sm rounded-pill text-uppercase">
                        <i class="bi bi-printer me-2"></i> Thanh toán & In hóa đơn
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* Giữ nguyên phần <script> của bạn *@
<script>
    let cart = [];

    function checkQty(id, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let btnAdd = document.getElementById('btn-add-' + id);
        let currentVal = parseInt(qtyInput.value);

        if (currentVal < 0 || isNaN(currentVal)) {
            qtyInput.value = 0;
            currentVal = 0;
        }

        if (currentVal > maxStock) {
            alert("Số lượng tồn kho không đủ! (Tối đa: " + maxStock + ")");
            qtyInput.value = maxStock;
            currentVal = maxStock;
        }

        if (currentVal === 0) {
            btnAdd.disabled = true;
            btnAdd.classList.replace('btn-primary', 'btn-secondary');
        } else {
            btnAdd.disabled = false;
            btnAdd.classList.replace('btn-secondary', 'btn-primary');
        }
    }

    function addToCart(id, name, price, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let qty = parseInt(qtyInput.value);

        if (isNaN(qty) || qty <= 0) return;

        let existingItem = cart.find(item => item.maSP === id);
        let totalInCart = (existingItem ? existingItem.soLuong : 0) + qty;

        if (totalInCart > maxStock) {
            alert("Không thể thêm! Tổng số lượng trong giỏ hàng vượt quá tồn kho.");
            return;
        }

        if (existingItem) {
            existingItem.soLuong += qty;
        } else {
            cart.push({ maSP: id, ten: name, soLuong: qty, donGia: price });
        }

        qtyInput.value = (maxStock > 0) ? 1 : 0;
        checkQty(id, maxStock);
        renderCart();
    }

    function renderCart() {
        let html = '';
        let total = 0;
        if (cart.length === 0) {
            html = `
                <li class="text-muted text-center py-5">
                    <i class="bi bi-cart-x display-4 d-block mb-2 opacity-25"></i>
                    Chưa có sản phẩm nào
                </li>`;
        } else {
            cart.forEach((item, index) => {
                let subTotal = item.soLuong * item.donGia;
                html += `
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <div class="ps-2">
                            <div class="fw-bold text-dark">${item.ten}</div>
                            <small class="text-muted">${item.donGia.toLocaleString()} x ${item.soLuong}</small>
                        </div>
                        <div class="text-end pe-2">
                            <div class="fw-bold text-primary">${subTotal.toLocaleString()} đ</div>
                            <button onclick="removeFromCart(${index})" class="btn btn-link btn-sm text-danger p-0 border-0 shadow-none"><i class="bi bi-trash"></i> Xóa</button>
                        </div>
                    </li>`;
                total += subTotal;
            });
        }
        document.getElementById('cart').innerHTML = html;
        document.getElementById('totalAmount').innerText = total.toLocaleString();
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        renderCart();
    }

    function finishOrder() {
        if (cart.length === 0) {
            alert("Giỏ hàng đang trống!");
            return;
        }

        let form = document.createElement("form");
        form.method = "POST";
        form.action = "/Invoice/Create";

        let ptThanhToan = document.getElementById("phuongThucThanhToan").value;
        appendHiddenInput(form, "phuongThucThanhToan", ptThanhToan);
        appendHiddenInput(form, "__RequestVerificationToken", document.querySelector('input[name="__RequestVerificationToken"]')?.value || "");

        cart.forEach((item, i) => {
            appendHiddenInput(form, `details[${i}].MaSP`, item.maSP);
            appendHiddenInput(form, `details[${i}].SoLuong`, item.soLuong);
            appendHiddenInput(form, `details[${i}].DonGia`, item.donGia);
        });

        document.body.appendChild(form);
        form.submit();
    }

    function appendHiddenInput(form, name, value) {
        let input = document.createElement("input");
        input.type = "hidden";
        input.name = name;
        input.value = value;
        form.appendChild(input);
    }
</script>

@section Scripts {
    <script>
        // JS tìm kiếm sản phẩm nhanh
        document.getElementById('searchProduct').addEventListener('keyup', function () {
            var searchValue = this.value.toLowerCase();
            var tableRows = document.querySelectorAll('#productList tr');
            tableRows.forEach(function (row) {
                var productName = row.cells[0].textContent.toLowerCase();
                if (productName.includes(searchValue)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}