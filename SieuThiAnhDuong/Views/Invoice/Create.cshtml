@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    ViewData["Title"] = "Lập hóa đơn bán hàng";
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h4 class="mb-0 text-primary"><i class="bi bi-search me-2"></i>Chọn sản phẩm</h4>
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="searchProduct" class="form-control" placeholder="Nhập tên sản phẩm để tìm nhanh...">
                    </div>
                </div>
            </div>
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Giá bán</th>
                            <th class="text-center">Tồn kho</th>
                            <th style="width: 130px;">Số lượng</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="productList">
                        @foreach (var p in ViewBag.Products)
                        {
                            <tr>
                                <td class="fw-bold">@p.TenSP</td>
                                <td class="text-danger">@p.GiaBan.ToString("N0") đ</td>
                                <td class="text-center">
                                    <span class="badge @(p.SoLuongTon > 0 ? "bg-info" : "bg-danger")">
                                        @p.SoLuongTon
                                    </span>
                                </td>
                                <td>
                                    @* Cập nhật max=@p.SoLuongTon để chặn nhập quá số lượng *@
                                    <input type="number" id="qty-@p.MaSP"
                                           value="@(p.SoLuongTon > 0 ? 1 : 0)"
                                           min="0"
                                           max="@p.SoLuongTon"
                                           oninput="checkQty(@p.MaSP, @p.SoLuongTon)"
                                           class="form-control form-control-sm text-center fw-bold"
                                    @(p.SoLuongTon <= 0 ? "disabled" : "") />
                                </td>
                                <td class="text-end">
                                    <button id="btn-add-@p.MaSP"
                                            onclick="addToCart(@p.MaSP, '@p.TenSP', @p.GiaBan, @p.SoLuongTon)"
                                            class="btn @(p.SoLuongTon > 0 ? "btn-primary" : "btn-secondary") btn-sm px-3"
                                        @(p.SoLuongTon <= 0 ? "disabled" : "")>
                                        <i class="bi bi-plus-circle me-1"></i> Thêm
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-success text-white py-3">
                <h4 class="mb-0"><i class="bi bi-cart3 me-2"></i>Giỏ hàng</h4>
            </div>
            <div class="card-body">
                <ul id="cart" class="list-group list-group-flush mb-3" style="min-height: 200px; max-height: 400px; overflow-y: auto;">
                    <li class="text-muted text-center py-4">Chưa có sản phẩm nào</li>
                </ul>
                <hr>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="h5 mb-0">Tổng cộng:</span>
                    <span class="h4 mb-0 text-danger fw-bold"><span id="totalAmount">0</span> đ</span>
                </div>
                <button onclick="finishOrder()" class="btn btn-success w-100 py-3 fw-bold shadow-sm">
                    <i class="bi bi-printer me-2"></i> THANH TOÁN & IN HÓA ĐƠN
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let cart = [];

    // 1. Hàm kiểm tra: Chặn số âm, chặn vượt quá tồn kho, khóa nút khi = 0
    function checkQty(id, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let btnAdd = document.getElementById('btn-add-' + id);
        let currentVal = parseInt(qtyInput.value);

        // Chặn số âm
        if (currentVal < 0 || isNaN(currentVal)) {
            qtyInput.value = 0;
            currentVal = 0;
        }

        // Chặn vượt quá tồn kho
        if (currentVal > maxStock) {
            alert("Số lượng tồn kho không đủ! (Tối đa: " + maxStock + ")");
            qtyInput.value = maxStock;
            currentVal = maxStock;
        }

        // Khóa nút nếu bằng 0
        if (currentVal === 0) {
            btnAdd.disabled = true;
            btnAdd.classList.replace('btn-primary', 'btn-secondary');
        } else {
            btnAdd.disabled = false;
            btnAdd.classList.replace('btn-secondary', 'btn-primary');
        }
    }

    // 2. Thêm vào giỏ hàng (Kiểm tra thêm tồn kho thực tế)
    function addToCart(id, name, price, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let qty = parseInt(qtyInput.value);

        if (isNaN(qty) || qty <= 0) return;

        // Tìm xem sản phẩm đã có trong giỏ chưa để tính tổng
        let existingItem = cart.find(item => item.maSP === id);
        let totalInCart = (existingItem ? existingItem.soLuong : 0) + qty;

        if (totalInCart > maxStock) {
            alert("Không thể thêm! Tổng số lượng trong giỏ hàng vượt quá tồn kho.");
            return;
        }

        if (existingItem) {
            existingItem.soLuong += qty;
        } else {
            cart.push({ maSP: id, ten: name, soLuong: qty, donGia: price });
        }

        // Reset ô nhập về 1 (nếu kho còn hàng), nếu không thì về 0
        qtyInput.value = (maxStock > 0) ? 1 : 0;
        checkQty(id, maxStock);
        renderCart();
    }

    // 3. Hiển thị giỏ hàng
    function renderCart() {
        let html = '';
        let total = 0;
        if (cart.length === 0) {
            html = '<li class="text-muted text-center py-4">Chưa có sản phẩm nào</li>';
        } else {
            cart.forEach((item, index) => {
                let subTotal = item.soLuong * item.donGia;
                html += `
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold">${item.ten}</div>
                            <small class="text-muted">${item.donGia.toLocaleString()} x ${item.soLuong}</small>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-primary">${subTotal.toLocaleString()} đ</div>
                            <button onclick="removeFromCart(${index})" class="btn btn-link btn-sm text-danger p-0 border-0"><i class="bi bi-trash"></i></button>
                        </div>
                    </li>`;
                total += subTotal;
            });
        }
        document.getElementById('cart').innerHTML = html;
        document.getElementById('totalAmount').innerText = total.toLocaleString();
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        renderCart();
    }

    // 4. Gửi dữ liệu thanh toán
    function finishOrder() {
        if (cart.length === 0) {
            alert("Giỏ hàng đang trống!");
            return;
        }

        let form = document.createElement("form");
        form.method = "POST";
        form.action = "/Invoice/Create";

        let inputMaNV = document.createElement("input");
        inputMaNV.type = "hidden";
        inputMaNV.name = "maNV";
        inputMaNV.value = "@(User.FindFirst("MaNV")?.Value ?? "1")";
        form.appendChild(inputMaNV);

        cart.forEach((item, i) => {
            appendHiddenInput(form, `details[${i}].MaSP`, item.maSP);
            appendHiddenInput(form, `details[${i}].SoLuong`, item.soLuong);
            appendHiddenInput(form, `details[${i}].DonGia`, item.donGia);
        });

        document.body.appendChild(form);
        form.submit();
    }

    function appendHiddenInput(form, name, value) {
        let input = document.createElement("input");
        input.type = "hidden";
        input.name = name;
        input.value = value;
        form.appendChild(input);
    }
</script>
@section Scripts {
    <script>
        // Bắt sự kiện mỗi khi gõ phím vào ô tìm kiếm
        document.getElementById('searchProduct').addEventListener('keyup', function () {
            var searchValue = this.value.toLowerCase();
            var tableRows = document.querySelectorAll('#productList tr');

            tableRows.forEach(function (row) {
                // Lấy nội dung của cột đầu tiên (Tên sản phẩm)
                var productName = row.cells[0].textContent.toLowerCase();
                
                // Ẩn/hiện dòng dựa trên kết quả tìm kiếm
                if (productName.includes(searchValue)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}