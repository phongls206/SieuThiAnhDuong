@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    ViewData["Title"] = "Lập hóa đơn bán hàng";
}

<style>
    /* 1. Khung chứa bảng: Tự động co giãn, tối đa 530px mới hiện thanh cuộn */
    .product-table-wrapper {
        max-height: 530px; 
        overflow-y: auto;
        overflow-x: hidden;
        -webkit-overflow-scrolling: touch;
        will-change: scroll-position;
    }

    /* 2. Cố định tiêu đề bảng */
    .product-table-wrapper thead th {
        position: sticky;
        top: 0;
        z-index: 10;
        background-color: #f8f9fa !important;
        box-shadow: inset 0 -1px 0 #dee2e6;
    }

    /* 3. Thanh cuộn */
    .product-table-wrapper::-webkit-scrollbar { width: 6px; }
    .product-table-wrapper::-webkit-scrollbar-track { background: transparent; }
    .product-table-wrapper::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }

    #productList tr { transform: translateZ(0); }

    /* --- Responsive Mobile --- */
    @@media (max-width: 767.98px) {
        .product-table-wrapper { max-height: 400px; } 
        .card-header h4 { font-size: 1.1rem; }
        #searchProduct { font-size: 0.9rem; }
        .table thead { display: none; } 
        .table td { display: block; text-align: left !important; border: none; padding: 0.5rem 1rem; }
        .table tr { display: block; border-bottom: 1px solid #eee; padding: 10px 0; }
        
        /* Hiển thị số lượng và nút bấm trên cùng 1 hàng ở mobile */
        .mobile-action-row {
            display: flex;
            align-items: center;
            justify-content:间-between;
            gap: 10px;
            padding: 0 1rem;
        }
    }
</style>

<div class="container-fluid mt-4">
    <div class="row g-4">
        @* --- CỘT BÊN TRÁI: DANH MỤC SẢN PHẨM --- *@
        <div class="col-12 col-md-8"> @* Chiếm 12 cột trên mobile, 8 cột trên PC *@
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <div class="row g-2 align-items-center">
                        <div class="col-12 col-sm-6">
                            <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-card-checklist me-2"></i>Danh mục</h4>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white border-primary text-primary"><i class="bi bi-search"></i></span>
                                <input type="text" id="searchProduct" class="form-control border-primary" placeholder="Tìm tên sản phẩm...">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive product-table-wrapper">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light d-none d-md-table-header-group">
                                <tr>
                                    <th class="ps-3">Sản phẩm</th>
                                    <th>Giá bán</th>
                                    <th class="text-center">Tồn kho</th>
                                    <th style="width: 140px;">Số lượng</th>
                                    <th class="text-end pe-3">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="productList">
                                @foreach (var p in ViewBag.Products)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-dark">
                                            <span class="d-md-none text-muted fw-normal small">Sản phẩm: </span>@p.TenSP
                                        </td>
                                        <td class="text-danger fw-bold">
                                            <span class="d-md-none text-muted fw-normal small">Giá: </span>@p.GiaBan.ToString("N0") đ
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex align-items-center justify-content-md-center">
                                                <span class="d-md-none text-muted fw-normal small me-2">Tồn: </span>
                                                @if (p.SoLuongTon <= 0) {
                                                    <span class="badge bg-danger shadow-sm py-2 px-3">Hết hàng</span>
                                                }
                                                else if (p.SoLuongTon < 10) {
                                                    <span class="badge bg-warning text-dark shadow-sm py-2 px-3">Sắp hết (@p.SoLuongTon)</span>
                                                }
                                                else {
                                                    <span class="badge bg-success shadow-sm py-2 px-3">Còn (@p.SoLuongTon)</span>
                                                }
                                            </div>
                                        </td>
                                        @* Group input và button lại để responsive *@
                                        <td colspan="2">
                                            <div class="d-flex align-items-center justify-content-between gap-2 px-2 px-md-0">
                                                <div style="width: 100px;">
                                                    <input type="number" id="qty-@p.MaSP"
                                                           value="@(p.SoLuongTon > 0 ? 1 : 0)"
                                                           min="0"
                                                           max="@p.SoLuongTon"
                                                           oninput="checkQty(@p.MaSP, @p.SoLuongTon)"
                                                           class="form-control form-control-sm text-center fw-bold border-primary"
                                                           @(p.SoLuongTon <= 0 ? "disabled" : "") />
                                                </div>
                                                <button id="btn-add-@p.MaSP"
                                                        onclick="addToCart(@p.MaSP, '@p.TenSP', @p.GiaBan, @p.SoLuongTon)"
                                                        class="btn @(p.SoLuongTon > 0 ? "btn-primary" : "btn-secondary") btn-sm px-3 shadow-sm flex-grow-1 flex-md-grow-0"
                                                        @(p.SoLuongTon <= 0 ? "disabled" : "")>
                                                    <i class="bi bi-plus-lg"></i> Thêm
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        @* --- CỘT BÊN PHẢI: GIỎ HÀNG --- *@
        <div class="col-12 col-md-4">
            <div class="card shadow border-0 overflow-hidden">
                <div class="card-header bg-success text-white py-3">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-cart3 me-2"></i>Giỏ hàng</h4>
                </div>
                <div class="card-body">
                    <ul id="cart" class="list-group list-group-flush mb-3" style="min-height: 150px; max-height: 400px; overflow-y: auto;">
                        <li class="text-muted text-center py-5">
                            <i class="bi bi-cart-x display-4 d-block mb-2 opacity-25"></i>
                            Chưa có sản phẩm nào
                        </li>
                    </ul>
                    <hr class="border-secondary opacity-25">

                    <div class="mb-4">
                        <label class="form-label fw-bold text-dark"><i class="bi bi-credit-card-2-back me-1"></i> Thanh toán:</label>
                        <select id="phuongThucThanhToan" class="form-select border-success shadow-sm">
                            <option value="Tiền mặt">💵 Tiền mặt</option>
                            <option value="Chuyển khoản">💳 Chuyển khoản</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded-3 shadow-sm border">
                        <span class="h5 mb-0 fw-bold">Tổng cộng:</span>
                        <span class="h4 mb-0 text-danger fw-bold"><span id="totalAmount">0</span> đ</span>
                    </div>

                    <button onclick="finishOrder()" class="btn btn-success w-100 py-3 fw-bold shadow-sm rounded-pill text-uppercase">
                        <i class="bi bi-printer me-2"></i> Thanh toán
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
   
    let cart = [];

    document.getElementById('searchProduct').addEventListener('input', function () {
        let filter = this.value.toLowerCase().trim();
        let rows = document.querySelectorAll('#productList tr');
        rows.forEach(row => {
            let productName = row.querySelector('td:first-child').innerText.toLowerCase();
            row.style.display = productName.includes(filter) ? "" : "none";
        });
    });

    function checkQty(id, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let btnAdd = document.getElementById('btn-add-' + id);
        let currentVal = parseInt(qtyInput.value);

        if (currentVal < 0 || isNaN(currentVal)) { qtyInput.value = 0; currentVal = 0; }
        if (currentVal > maxStock) {
            Swal.fire({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, icon: 'warning', title: 'Tối đa: ' + maxStock });
            qtyInput.value = maxStock;
            currentVal = maxStock;
        }

        if (currentVal === 0) {
            btnAdd.disabled = true;
            btnAdd.classList.replace('btn-primary', 'btn-secondary');
        } else {
            btnAdd.disabled = false;
            btnAdd.classList.replace('btn-secondary', 'btn-primary');
        }
    }

    function addToCart(id, name, price, maxStock) {
        let qtyInput = document.getElementById('qty-' + id);
        let qty = parseInt(qtyInput.value);
        if (isNaN(qty) || qty <= 0) return;

        let existingItem = cart.find(item => item.maSP === id);
        let totalInCart = (existingItem ? existingItem.soLuong : 0) + qty;

        if (totalInCart > maxStock) {
            Swal.fire({ icon: 'error', title: 'Hết hàng!', text: 'Tổng số lượng vượt quá tồn kho.', confirmButtonText: 'Đã hiểu' });
            return;
        }

        if (existingItem) existingItem.soLuong += qty;
        else cart.push({ maSP: id, ten: name, soLuong: qty, donGia: price });

        Swal.fire({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1500, icon: 'success', title: 'Đã thêm vào giỏ' });
        qtyInput.value = (maxStock > 0) ? 1 : 0;
        checkQty(id, maxStock);
        renderCart();
    }

    function renderCart() {
        let html = '';
        let total = 0;
        if (cart.length === 0) {
            html = `<li class="text-muted text-center py-5"><i class="bi bi-cart-x display-4 d-block mb-2 opacity-25"></i>Chưa có sản phẩm nào</li>`;
        } else {
            cart.forEach((item, index) => {
                let subTotal = item.soLuong * item.donGia;
                html += `
                    <li class="list-group-item px-0 d-flex justify-content-between align-items-center animate__animated animate__fadeIn">
                        <div class="ps-2">
                            <div class="fw-bold text-dark">${item.ten}</div>
                            <small class="text-muted">${item.donGia.toLocaleString()} x ${item.soLuong}</small>
                        </div>
                        <div class="text-end pe-2">
                            <div class="fw-bold text-primary">${subTotal.toLocaleString()} đ</div>
                            <button onclick="removeFromCart(${index})" class="btn btn-link btn-sm text-danger p-0 border-0 shadow-none"><i class="bi bi-trash"></i></button>
                        </div>
                    </li>`;
                total += subTotal;
            });
        }
        document.getElementById('cart').innerHTML = html;
        document.getElementById('totalAmount').innerText = total.toLocaleString();
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        renderCart();
    }

    function finishOrder() {
        if (cart.length === 0) {
            Swal.fire({ icon: 'info', title: 'Giỏ hàng trống!' });
            return;
        }

        Swal.fire({
            title: 'Xác nhận thanh toán?',
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#198754',
            confirmButtonText: 'Đúng, hoàn tất!',
            cancelButtonText: 'Kiểm tra lại'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.showLoading();
                let form = document.createElement("form");
                form.method = "POST";
                form.action = "/Invoice/Create";
                appendHiddenInput(form, "phuongThucThanhToan", document.getElementById("phuongThucThanhToan").value);
                cart.forEach((item, i) => {
                    appendHiddenInput(form, `details[${i}].MaSP`, item.maSP);
                    appendHiddenInput(form, `details[${i}].SoLuong`, item.soLuong);
                    appendHiddenInput(form, `details[${i}].DonGia`, item.donGia);
                });
                document.body.appendChild(form);
                form.submit();
            }
        });
    }

    function appendHiddenInput(form, name, value) {
        let input = document.createElement("input");
        input.type = "hidden"; input.name = name; input.value = value;
        form.appendChild(input);
    }
</script>