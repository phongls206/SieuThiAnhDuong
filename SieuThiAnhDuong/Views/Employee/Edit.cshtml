@model SieuThiAnhDuong.Models.NhanVien

<div class="container mt-3 pb-4">
    <div class="row justify-content-center">
        @* Giới hạn độ rộng hợp lý cho PC và Mobile *@
        <div class="col-12 col-md-7 col-lg-5 col-xl-4">
            <div class="card shadow-sm border-0">
                @* Thu nhỏ header để nhường chỗ cho nội dung *@
                <div class="card-header bg-white py-2 border-bottom">
                    <h5 class="fw-bold text-primary mb-0 text-center">
                        <i class="bi bi-pencil-square me-1"></i> CẬP NHẬT NHÂN VIÊN
                    </h5>
                </div>
                
                <div class="card-body p-3">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="MaNV" />

                        @* Họ và tên - Giảm mb-3 xuống mb-2 *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Họ và tên</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light text-primary"><i class="bi bi-person"></i></span>
                                <input asp-for="HoTen" class="form-control" placeholder="Họ tên..." />
                            </div>
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>

                        @* Giới tính & Chức vụ - Cho nằm cùng 1 hàng để tiết kiệm diện tích *@
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label fw-bold small mb-1">Giới tính</label>
                                <select asp-for="GioiTinh" class="form-select form-select-sm" required>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold small mb-1">Chức vụ</label>
                                <select asp-for="ChucVu" class="form-select form-select-sm border-primary">
                                    <option value="Admin">Admin</option>
                                    <option value="Thủ kho">Thủ kho</option>
                                    <option value="Nhân viên">Nhân viên</option>
                                </select>
                            </div>
                        </div>

                        @* Ngày sinh *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Ngày sinh</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light text-primary"><i class="bi bi-calendar-event"></i></span>
                                <input asp-for="NgaySinh" type="date" class="form-control" />
                            </div>
                        </div>

                        @* Số điện thoại *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Số điện thoại</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light text-primary"><i class="bi bi-telephone"></i></span>
                                <input asp-for="SoDT" class="form-control" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            </div>
                        </div>

                        @* Địa chỉ *@
                        <div class="mb-3">
                            <label class="form-label fw-bold small mb-1">Địa chỉ</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light text-primary"><i class="bi bi-geo-alt"></i></span>
                                <textarea asp-for="DiaChi" class="form-control" rows="2" style="font-size: 0.85rem;"></textarea>
                            </div>
                        </div>

                        @* Nút bấm - Căn giữa và gọn gàng *@
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-sm fw-bold">
                                <i class="bi bi-save me-1"></i> Lưu thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Ép kích thước chữ nhỏ lại một chút để không bị tràn màn hình laptop/mobile */
    .form-control-sm, .form-select-sm, .input-group-text {
        padding: 0.4rem 0.6rem;
    }
    
    label {
        color: #555;
    }

    /* Đảm bảo card không quá dài */
    .card {
        border-radius: 12px;
        overflow: hidden;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}