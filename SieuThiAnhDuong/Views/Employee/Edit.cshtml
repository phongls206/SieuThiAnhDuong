@model SieuThiAnhDuong.Models.NhanVien

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-white py-3">
                    <h4 class="fw-bold text-primary mb-0"><i class="bi bi-pencil-square me-2"></i>CẬP NHẬT NHÂN VIÊN</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="MaNV" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person"></i></span>
                                <input asp-for="HoTen" class="form-control" placeholder="Nhập họ tên nhân viên" />
                            </div>
                            <span asp-validation-for="HoTen" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Giới tính </label>
                            <select asp-for="GioiTinh" class="form-select shadow-sm" required>
                                <option value="">-- Chọn giới tính --</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                            @* Dòng này sẽ hiện chữ đỏ "Vui lòng chọn giới tính" nếu để trống *@
                            <span asp-validation-for="GioiTinh" class="text-danger small"></span>
                        </div>
                        @* Cột mới: Ngày sinh *@
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày sinh</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-calendar-event"></i></span>
                                <input asp-for="NgaySinh" type="date" class="form-control" />
                            </div>
                            <span asp-validation-for="NgaySinh" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Chức vụ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-briefcase"></i></span>
                                <select asp-for="ChucVu" class="form-select border-primary">
                                    <option value="Admin">Admin</option>
                                    <option value="Thủ kho">Thủ kho</option>
                                    <option value="Nhân viên">Nhân viên</option>
                                </select>
                            </div>
                            <span asp-validation-for="ChucVu" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                                <input asp-for="SoDT" class="form-control"
                                       maxlength="10"
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '');"
                                       placeholder="Nhập đủ 10 chữ số..." />
                            </div>
                            <span asp-validation-for="SoDT" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                                <textarea asp-for="DiaChi" class="form-control" rows="2" placeholder="Địa chỉ thường trú..."></textarea>
                            </div>
                            <span asp-validation-for="DiaChi" class="text-danger"></span>
                        </div>

                        <hr />
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light border">Hủy bỏ</a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                <i class="bi bi-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}