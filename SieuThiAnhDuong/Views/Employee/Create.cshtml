@model SieuThiAnhDuong.Models.NhanVien

<div class="container mt-3 pb-4">
    <div class="row justify-content-center">
        @* Khống chế độ rộng: col-lg-5 cho PC, col-12 cho Mobile *@
        <div class="col-12 col-md-8 col-lg-5 col-xl-4">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-2">
                    <h5 class="mb-0 text-nowrap text-center">
                        <i class="bi bi-person-plus-fill me-2"></i>THÊM NHÂN VIÊN MỚI
                    </h5>
                </div>
                <div class="card-body p-3">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2 fw-bold small"></div>

                        @* Họ và tên *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Họ và tên</label>
                            <input asp-for="HoTen" class="form-control form-control-sm" placeholder="Nhập đầy đủ họ tên..." />
                            <span asp-validation-for="HoTen" class="text-danger" style="font-size: 0.75rem;"></span>
                        </div>

                        @* Giới tính & Chức vụ *@
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label fw-bold small mb-1">Giới tính</label>
                                <select asp-for="GioiTinh" class="form-select form-select-sm" required>
                                    <option value="">-- Chọn --</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="GioiTinh" class="text-danger" style="font-size: 0.75rem;"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold small mb-1">Chức vụ</label>
                                <select asp-for="ChucVu" class="form-select form-select-sm border-primary">
                                    <option value="">-- Chọn --</option>
                                    <option value="Admin">Admin</option>
                                    <option value="Thủ kho">Thủ kho</option>
                                    <option value="Nhân viên">Nhân viên</option>
                                </select>
                                <span asp-validation-for="ChucVu" class="text-danger" style="font-size: 0.75rem;"></span>
                            </div>
                        </div>

                        @* Ngày sinh *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Ngày sinh</label>
                            <input asp-for="NgaySinh" type="date" class="form-control form-control-sm"
                                   max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="NgaySinh" class="text-danger" style="font-size: 0.75rem;"></span>
                        </div>

                        @* Số điện thoại *@
                        <div class="mb-2">
                            <label class="form-label fw-bold small mb-1">Số điện thoại</label>
                            <input asp-for="SoDT" class="form-control form-control-sm" maxlength="10"
                                   placeholder="Đủ 10 số..." oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            <span asp-validation-for="SoDT" class="text-danger" style="font-size: 0.75rem;"></span>
                        </div>

                        @* Địa chỉ *@
                        <div class="mb-3">
                            <label class="form-label fw-bold small mb-1">Địa chỉ</label>
                            <input asp-for="DiaChi" class="form-control form-control-sm" placeholder="Số nhà, tên đường..." />
                            <span asp-validation-for="DiaChi" class="text-danger" style="font-size: 0.75rem;"></span>
                        </div>

                        <div class="d-grid gap-2 pt-2 border-top">
                            <button type="submit" class="btn btn-primary btn-sm fw-bold">
                                <i class="bi bi-save me-2"></i>LƯU NHÂN VIÊN
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">HỦY BỎ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Giúp thông báo lỗi hiện ngay dưới ô input mà không làm vỡ form */
    .text-danger {
        display: block;
        margin-top: 2px;
        font-weight: 500;
    }
    .card { border-radius: 10px; overflow: hidden; }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}