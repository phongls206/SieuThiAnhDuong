@model SieuThiAnhDuong.Models.NhanVien

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4>Thêm Nhân Viên Mới</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">Họ và tên</label>
                    <input asp-for="HoTen" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="DiaChi" class="form-control" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="SoDT" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Chức vụ</label>
                        <select asp-for="ChucVu" class="form-control">
                            <option value="Admin">Admin</option>
                            <option value="Thủ kho">Thủ kho</option> @* Đảm bảo value và chữ hiển thị giống hệt nhau *@
                            <option value="Nhân viên">Nhân viên</option>
                        </select>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Lưu nhân viên</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>