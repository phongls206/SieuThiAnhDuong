@model SieuThiAnhDuong.Models.NhanVien

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-plus-fill me-2"></i>Thêm Nhân Viên Mới</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @* SỬA DÒNG NÀY: Thay "All" bằng "ModelOnly" để ẩn lỗi hệ thống tiếng Anh *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Họ và tên</label>
                    <input asp-for="HoTen" class="form-control" placeholder="Nhập đầy đủ họ tên..." />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Giới tính</label>
                    <select asp-for="GioiTinh" class="form-select shadow-sm" required>
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nam">Nam</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Khác">Khác</option>
                    </select>
                    @* Dòng này sẽ hiện chữ đỏ "Vui lòng chọn giới tính" nếu để trống *@
                    <span asp-validation-for="GioiTinh" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="form-control" min="1900-01-01"
                           max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="NgaySinh" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Địa chỉ</label>
                    <input asp-for="DiaChi" class="form-control" placeholder="Số nhà, tên đường, quận/huyện..." />
                    <span asp-validation-for="DiaChi" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="SoDT" class="form-control"
                               maxlength="10"
                               placeholder="Phải đủ 10 số..."
                               oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                        <span asp-validation-for="SoDT" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Chức vụ</label>
                        <select asp-for="ChucVu" class="form-select border-primary">
                            <option value="">-- Chọn chức vụ --</option>
                            <option value="Admin">Admin</option>
                            <option value="Thủ kho">Thủ kho</option>
                            <option value="Nhân viên">Nhân viên</option>
                        </select>
                        <span asp-validation-for="ChucVu" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 border-top pt-3">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                        <i class="bi bi-save me-2"></i>Lưu nhân viên
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}