@model IEnumerable<SieuThiAnhDuong.Models.NhanVien>

@* ... Phần tiêu đề và thông báo giữ nguyên ... *@

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Mã NV</th>
            <th>Họ tên</th>
            <th>Chức vụ</th>
            <th>Số điện thoại</th>
            <th>Địa chỉ</th>
            <th class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-bold">#@item.MaNV</td>
                <td>@item.HoTen</td>
                <td>
                    @if (item.ChucVu == "Admin")
                    {
                        <span class="badge bg-danger">Admin</span>
                    }
                    else if (item.ChucVu == "Thủ kho")
                    {

                        <span class="badge bg-info">Thủ kho</span>
                    }
                    else
                    {

                        <span class="badge bg-primary">Nhân viên</span>
                    }
                </td>
                <td>@item.SoDT</td>
                <td>@item.DiaChi</td>
                <td class="text-center">
                    <div class="d-flex justify-content-center gap-1">
                        <a asp-action="Edit" asp-route-id="@item.MaNV" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil-square"></i>
                        </a>

                        @* CHẶN XÓA ADMIN PHONG (ID #1) *@
                        @if (item.MaNV != 1)
                        {
                            <form asp-action="Delete" method="post" onsubmit="return confirm('Xóa nhân viên này?')">
                                <input type="hidden" name="id" value="@item.MaNV" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary" disabled title="Không thể xóa Admin">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>