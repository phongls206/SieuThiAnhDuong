<div class="container mt-4">
    <h2>Thống kê doanh thu theo Quý</h2>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-3">
                <div class="card border-success mb-3">
                    <div class="card-header">Quý @item.Quater - Năm @item.Year</div>
                    <div class="card-body text-success">
                        <h5 class="card-title">@item.Total.ToString("N0") đ</h5>
                        <p class="card-text">Tổng doanh thu trong quý.</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>