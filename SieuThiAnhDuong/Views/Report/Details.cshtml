@model SieuThiAnhDuong.Models.HoaDon

@{
    // Lấy chức vụ từ Claims để phân quyền hiển thị nút
    var chucVu = User.FindFirst("ChucVu")?.Value ?? "";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Monthly">Thống kê</a></li>
            <li class="breadcrumb-item active">Chi tiết hóa đơn #@Model.MaHD</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white p-3">
            <h5 class="mb-0">THÔNG TIN HÓA ĐƠN #@Model.MaHD</h5>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <p class="text-muted mb-1">Nhân viên thực hiện:</p>
                    <h5 class="fw-bold">@Model.NhanVien?.HoTen</h5>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="text-muted mb-1">Thời gian lập đơn:</p>
                    <h5 class="fw-bold">@Model.NgayLap.ToString("dd/MM/yyyy HH:mm:ss")</h5>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Tên hàng hóa</th>
                            <th>Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ChiTietHoaDons != null)
                        {
                            foreach (var ct in Model.ChiTietHoaDons)
                            {
                                <tr>
                                    <td class="ps-3">@ct.SanPham?.TenSP</td>
                                    <td class="text-center">@ct.SoLuong</td>
                                    <td class="text-end">@ct.DonGia.ToString("N0") đ</td>
                                    <td class="text-end fw-bold">@((ct.SoLuong * ct.DonGia).ToString("N0")) đ</td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end">TỔNG CỘNG THANH TOÁN:</th>
                            <th class="text-end text-danger fs-5">@Model.TongTien.ToString("N0") đ</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <a asp-action="Monthly" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>

                @* CHỈ HIỆN NÚT IN NẾU KHÔNG PHẢI THỦ KHO *@
                @if (chucVu != "Thủ kho")
                {
                    <button onclick="window.print()" class="btn btn-dark">
                        <i class="bi bi-printer"></i> In hóa đơn
                    </button>
                }
                else
                {
                    <span class="text-muted small align-self-center">
                        
                    </span>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        @@media print {
            /* Ẩn các nút và thanh breadcrumb khi in thực tế */
            .btn, .breadcrumb, .sidebar, .top-info {
                display: none !important;
            }
            .card {
                border: none !important;
                box-shadow: none !important;
            }
            .card-header {
                background-color: #0d6efd !important;
                color: white !important;
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
}