@model SieuThiAnhDuong.Models.HoaDon

@{
    ViewData["Title"] = "Chi tiết hóa đơn #" + Model.MaHD;
    var chucVu = User.FindFirst("ChucVu")?.Value ?? "";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Monthly">Thống kê</a></li>
            <li class="breadcrumb-item active">Chi tiết hóa đơn #@Model.MaHD</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white p-3">
            <h5 class="mb-0 text-uppercase">THÔNG TIN HÓA ĐƠN #@Model.MaHD</h5>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-4">
                    <p class="text-muted mb-1">Mã hóa đơn:</p>
                    <h5 class="fw-bold text-primary">#@Model.MaHD</h5>
                    
                    <p class="text-muted mb-1 mt-3">Thu ngân:</p>
                    <h6 class="fw-bold">@Model.NhanVien?.HoTen</h6>
                </div>
                <div class="col-md-4">
                    <p class="text-muted mb-1">Ngày lập:</p>
                    <h6 class="fw-bold">@Model.NgayLap.ToString("dd/MM/yyyy")</h6>
                    
                    <p class="text-muted mb-1 mt-3">Giờ xuất:</p>
                    <h6 class="fw-bold">@Model.NgayLap.ToString("HH:mm:ss")</h6>
                </div>
                <div class="col-md-4 text-md-end">
                    <p class="text-muted mb-1">Ca trực:</p>
                    <span class="badge bg-info text-dark fw-bold">@Model.CaTruc</span>
                    
                    <p class="text-muted mb-1 mt-3">Phương thức:</p>
                    <h6 class="fw-bold">@Model.PhuongThucThanhToan</h6>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light text-center">
                        <tr class="text-uppercase" style="font-size: 0.9rem;">
                            <th>Sản phẩm</th>
                            <th>Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ct in Model.ChiTietHoaDons)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-bold">@ct.SanPham?.TenSP</div>
                                    <small class="text-muted">Mã SP: @ct.MaSP</small>
                                </td>
                                <td class="text-center">@ct.SoLuong</td>
                                <td class="text-end">@ct.DonGia.ToString("N0") đ</td>
                                <td class="text-end fw-bold">@((ct.SoLuong * ct.DonGia).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th colspan="3" class="text-end text-uppercase">Tổng cộng thanh toán:</th>
                            <th class="text-end text-danger fs-5">@Model.TongTien.ToString("N0") đ</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="mt-4 d-flex justify-content-between">
                <a asp-action="Monthly" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>

                @if (chucVu != "Thủ kho")
                {
                    <button type="button" onclick="printHiddenFrame('/Invoice/Print/@Model.MaHD')" class="btn btn-dark px-4 shadow">
                        <i class="bi bi-printer-fill me-2"></i> IN HÓA ĐƠN
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<iframe id="printf" name="printf" style="display:none;"></iframe>

<script>
    function printHiddenFrame(url) {
        var iframe = document.getElementById('printf');
        iframe.src = url;
        iframe.onload = function () {
            setTimeout(function () {
                iframe.contentWindow.focus();
                iframe.contentWindow.print();
            }, 500);
        };
    }
</script>