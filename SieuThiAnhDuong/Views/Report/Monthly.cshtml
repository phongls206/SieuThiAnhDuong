@model IEnumerable<SieuThiAnhDuong.Models.HoaDon>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-graph-up"></i> Báo cáo & Thống kê</h3>
    </div>

    @* --- Phần Card thống kê tổng quát --- *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white p-3 h-100 card-stat" onclick="filterByMethod('')">
                <div class="d-flex justify-content-between align-items-center">
                    <div><small class="opacity-75">Số lượng hóa đơn</small><h3 class="fw-bold mb-0">@ViewBag.SoHoaDon</h3></div>
                    <i class="bi bi-receipt fs-1 opacity-50 d-none d-sm-block"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white p-3 h-100 card-stat" onclick="sortByPriceDesc()">
                <div class="d-flex justify-content-between align-items-center">
                    <div><small class="opacity-75">Doanh thu tổng</small><h3 class="fw-bold mb-0">@ViewBag.TongDoanhThu.ToString("N0") đ</h3></div>
                    <i class="bi bi-wallet2 fs-1 opacity-50 d-none d-sm-block"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0 bg-info text-white p-3 h-100 card-stat" onclick="filterByMethod('Tiền mặt')">
                <div class="d-flex justify-content-between align-items-center">
                    <div><small class="opacity-75">Tổng tiền mặt </small><h3 class="fw-bold mb-0">@ViewBag.TienMat.ToString("N0") đ</h3></div>
                    <i class="bi bi-cash-stack fs-1 opacity-50 d-none d-sm-block"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-0 bg-warning text-white p-3 h-100 card-stat" onclick="filterByMethod('Chuyển khoản')">
                <div class="d-flex justify-content-between align-items-center">
                    <div><small class="opacity-75">Chuyển khoản </small><h3 class="fw-bold mb-0">@ViewBag.Banking.ToString("N0") đ</h3></div>
                    <i class="bi bi-credit-card fs-1 opacity-50 d-none d-sm-block"></i>
                </div>
            </div>
        </div>
    </div>

    @* --- Khu vực Bộ lọc Server-side --- *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Monthly" method="get" id="serverFilterForm" class="row g-3">
                <div class="col-12 col-md-3">
                    <label class="form-label small fw-bold text-primary">Tìm kiếm nhanh...</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-primary text-primary"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control border-primary" placeholder="Mã đơn, tên NV..." value="@ViewBag.CurrentSearch">
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label small fw-bold text-primary">Lọc thời gian</label>
                    <div class="input-group shadow-sm">
                        <select id="filterType" name="filterType" class="form-select border-primary" style="max-width: 100px;" onchange="updateInputType()">
                            <option value="date" selected="@(ViewBag.FilterType == "date")">Ngày</option>
                            <option value="month" selected="@(ViewBag.FilterType == "month")">Tháng</option>
                            <option value="year" selected="@(ViewBag.FilterType == "year")">Năm</option>
                        </select>
                        <input type="date" name="searchDate" id="timeInput" class="form-control border-primary" value="@ViewBag.CurrentDate">
                    </div>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-bold text-primary">Nhân viên</label>
                    @if (User.FindFirst("Quyen")?.Value == "Admin") {
                        <select name="selectNV" class="form-select border-secondary shadow-sm">
                            <option value="">-- Tất cả --</option>
                            @foreach (var nv in ViewBag.NhanVienList) {
                                <option value="@nv.MaNV" selected="@(ViewBag.CurrentNV == nv.MaNV)">@nv.HoTen</option>
                            }
                        </select>
                    } else {
                        <input type="text" class="form-control bg-light" value="@User.Identity.Name" readonly>
                    }
                </div>

                <div class="col-6 col-md-3 d-flex align-items-end gap-2">
                    <div class="flex-grow-1">
                        <label class="form-label small fw-bold text-primary">Ca làm việc</label>
                        <select name="selectCa" class="form-select shadow-sm">
                            <option value="">-- Tất cả --</option>
                            <option value="Ca 1 (Sáng)" selected="@(ViewBag.CurrentCa == "Ca 1 (Sáng)")">Ca 1 (7:00 - 14:30)</option>
                            <option value="Ca 2 (Chiều)" selected="@(ViewBag.CurrentCa == "Ca 2 (Chiều)")">Ca 2 (14:30 - 22:00)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary fw-bold shadow-sm" style="height: 38px;"><i class="bi bi-funnel-fill"></i></button>
                    <a asp-action="Monthly" class="btn btn-outline-secondary shadow-sm" style="height: 38px;"><i class="bi bi-arrow-clockwise"></i></a>
                </div>
            </form>
        </div>
    </div>

    @* --- Bảng dữ liệu hóa đơn --- *@
    <div class="card shadow-sm border-0 mb-5">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 text-secondary fw-bold"><i class="bi bi-table me-2"></i> Chi tiết các đơn hàng</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="invoiceTable" class="table table-hover align-middle mb-0">
                    <thead class="table-dark text-white">
                        <tr>
                            <th class="ps-4 no-sort">Mã đơn</th>
                            <th class="can-sort">Ngày & Giờ lập</th>
                            <th class="can-sort">Người bán</th>
                            <th class="text-center no-sort">Ca</th>
                            <th class="text-center no-sort">Hình thức</th>
                            <th class="text-end can-sort pe-4">Thành tiền</th>
                            <th class="text-center pe-4 no-sort">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.MaHD</td>
                                <td data-sort="@item.NgayLap.ToString("yyyyMMddHHmmss")">
                                    <div class="fw-bold">@item.NgayLap.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">@item.NgayLap.ToString("HH:mm:ss")</div>
                                </td>
                                <td>@item.NhanVien?.HoTen <br/><small class="text-muted">#@item.MaNV</small></td>
                                <td class="text-center">
                                    <span class="badge @(item.CaTruc?.Contains("1")==true ? "bg-info" : "bg-warning text-dark") px-3 py-2">@item.CaTruc</span>
                                </td>
                                <td class="text-center">
                                    @if (item.PhuongThucThanhToan == "Tiền mặt") {
                                        <span class="badge-payment bg-success-light text-success"><i class="bi bi-cash me-1"></i> @item.PhuongThucThanhToan</span>
                                    } else {
                                        <span class="badge-payment bg-primary-light text-primary"><i class="bi bi-credit-card me-1"></i> @item.PhuongThucThanhToan</span>
                                    }
                                </td>
                                @* FIX: Thêm data-sort bằng số nguyên thuần túy *@
                                <td class="text-end fw-bold text-danger pe-4" data-sort="@((long)item.TongTien)">
                                    @item.TongTien.ToString("N0") đ
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="Details" asp-route-id="@item.MaHD" class="btn btn-outline-primary btn-sm rounded-circle"><i class="bi bi-eye"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function updateInputType() {
            const type = document.getElementById('filterType').value;
            const input = document.getElementById('timeInput');
            if (type === 'date') {
                input.type = 'date';
            } else if (type === 'month') {
                input.type = 'month';
            } else if (type === 'year') {
                input.type = 'number';
                input.placeholder = "Nhập năm (VD: 2026)";
            }
        }

        $(document).ready(function () {
            updateInputType();

            var table = $('#invoiceTable').DataTable({
                "dom": 'rt<"d-flex flex-column flex-md-row justify-content-between align-items-center p-3"ip>',
                "pageLength": 10,
                "ordering": true,
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "columnDefs": [
                    { "orderable": false, "targets": "no-sort" },
                    { "type": "num", "targets": 5 } // Ép DataTables hiểu cột 5 là kiểu số
                ],
                "order": [[1, 'desc']]
            });

            $('#serverFilterForm').on('submit', function (e) {
                var search = $('input[name="searchString"]').val().trim();
                var nv = $('select[name="selectNV"]').val();
                var date = $('input[name="searchDate"]').val();
                var ca = $('select[name="selectCa"]').val();

                if (!search && !nv && !date && !ca) {
                    e.preventDefault(); 
                    Swal.fire({ icon: 'info', title: 'Thông báo', text: 'Vui lòng chọn ít nhất một điều kiện để lọc!', confirmButtonColor: '#0d6efd' });
                    return false;
                }
            });
        });

        function filterByMethod(method) {
            var table = $('#invoiceTable').DataTable();
            table.column(4).search(method).draw();
            scrollToTable();
        }

        function sortByPriceDesc() {
            var table = $('#invoiceTable').DataTable();
            // Clear các sắp xếp cũ và ưu tiên sắp xếp cột tiền (index 5) giảm dần
            table.order([5, 'desc']).draw();
            scrollToTable();
        }

        function scrollToTable() {
            $('html, body').animate({ scrollTop: $("#invoiceTable").offset().top - 100 }, 500);
        }
    </script>

    <style>
        @@media (max-width: 768px) {
            h3 { font-size: 1.25rem; }
            .card-stat h3 { font-size: 1.1rem !important; }
        }
        table.dataTable thead th::before, table.dataTable thead th::after { content: none !important; display: none !important; }
        .can-sort::before { content: "↕"; display: inline-block; margin-right: 5px; opacity: 0.3; }
        .card-stat { transition: transform 0.2s; cursor: pointer; }
        .card-stat:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
        .badge-payment { padding: 6px 12px; border-radius: 8px; font-weight: 600; font-size: 0.85rem; display: inline-flex; align-items: center; }
        .bg-success-light { background-color: rgba(25, 135, 84, 0.12) !important; }
        .bg-primary-light { background-color: rgba(13, 110, 253, 0.12) !important; }
    </style>
}