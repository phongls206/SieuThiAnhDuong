@model IEnumerable<SieuThiAnhDuong.Models.HoaDon>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-primary text-white p-3">
                <small>Tổng số hóa đơn</small>
                <h3 class="fw-bold">@ViewBag.SoHoaDon</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-success text-white p-3">
                <small>Tổng doanh thu</small>
                <h3 class="fw-bold">@ViewBag.TongDoanhThu.ToString("N0") đ</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-info text-white p-3">
                <small>Số hóa đơn hôm nay</small>
                <h3 class="fw-bold">@ViewBag.HoaDonHomNay</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 bg-warning text-white p-3">
                <small>Tổng tiền hôm nay</small>
                <h3 class="fw-bold">@ViewBag.DoanhThuHomNay.ToString("N0") đ</h3>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form asp-action="Monthly" method="get" class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control" placeholder="Tìm theo tên nhân viên...">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-calendar3"></i></span>
                        <input type="date" name="searchDate" class="form-control">
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc dữ liệu</button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Monthly" class="btn btn-outline-secondary w-100">Làm mới</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Mã HD</th>
                        <th>Ngày Bán</th>
                        <th>Tên Nhân Viên</th>
                        <th class="text-end">Tổng Tiền</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@item.MaHD</td>
                            <td>@item.NgayLap.ToString("dd/MM/yyyy")</td>
                            <td>@item.NhanVien?.HoTen</td>
                            <td class="text-end fw-bold text-danger">@item.TongTien.ToString("N0") đ</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.MaHD" class="btn btn-sm btn-outline-info">Chi tiết</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>