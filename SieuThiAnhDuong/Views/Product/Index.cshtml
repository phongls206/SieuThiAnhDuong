@model IEnumerable<SieuThiAnhDuong.Models.SanPham>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-box-seam"></i> Danh sách hàng hoá</h3>
        <a asp-action="Create" class="btn btn-success shadow-sm px-4">
            <i class="bi bi-plus-circle me-1"></i> Thêm mặt hàng mới
        </a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group shadow-sm" style="max-width: 500px;">
            <input type="text" name="searchString" class="form-control border-primary" placeholder="Nhập tên sản phẩm cần tìm..." />
            <button class="btn btn-primary px-4" type="submit">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Mã SP</th>
                            <th>Tên sản phẩm</th>
                            <th style="width: 150px;">Giá bán</th>
                            <th style="width: 150px;">Tồn kho</th>
                            <th style="width: 120px;">Đơn vị</th>
                            <th class="text-center" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@item.MaSP</td>
                                <td>
                                    <div class="fw-bold text-dark">@item.TenSP</div>
                                </td>
                                <td class="text-danger fw-bold">@item.GiaBan.ToString("N0") đ</td>
                                <td>
                                    @if (item.SoLuongTon < 0)
                                    {
                                        <span class="badge bg-danger shadow-sm py-2 px-3 w-100">
                                            <i class="bi bi-exclamation-octagon me-1"></i> Lỗi âm (@item.SoLuongTon)
                                        </span>
                                    }
                                    else if (item.SoLuongTon == 0)
                                    {
                                        <span class="badge bg-secondary shadow-sm py-2 px-3 w-100">
                                            Hết hàng
                                        </span>
                                    }
                                    else if (item.SoLuongTon <= 10)
                                    {
                                        <span class="badge bg-warning text-dark shadow-sm py-2 px-3 w-100">
                                            Sắp hết (@item.SoLuongTon)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border shadow-sm py-2 px-3 w-100">
                                            @item.SoLuongTon
                                        </span>
                                    }
                                </td>
                                <td><span class="text-muted">@item.DonViTinh</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.MaSP"
                                               class="btn btn-sm btn-outline-warning px-3" title="Sửa">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.MaSP" method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3" title="Xóa">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>