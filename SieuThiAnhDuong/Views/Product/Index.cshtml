@model IEnumerable<SieuThiAnhDuong.Models.SanPham>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary"><i class="bi bi-box-seam"></i> Danh sách hàng hoá</h3>
        <a asp-action="Create" class="btn btn-success shadow-sm px-4">
            <i class="bi bi-plus-circle me-1"></i> Thêm mặt hàng mới
        </a>
    </div>

    @* --- THANH TÌM KIẾM LINH ĐỘNG (Đã sửa từ form thành input trực tiếp) --- *@
    <div class="mb-4">
        <div class="input-group shadow-sm" style="max-width: 500px;">
            <span class="input-group-text bg-white border-primary text-primary"><i class="bi bi-search"></i></span>
            <input type="text" id="productSearchInput" class="form-control border-primary"
                   placeholder="Nhập tên sản phẩm hoặc mã SP để tìm nhanh..." />
        </div>
    </div>


    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4" style="width: 100px;">Mã SP</th>
                            <th>Tên sản phẩm</th>
                            <th style="width: 150px;">Giá bán</th>
                            <th style="width: 180px;">Tồn kho</th>
                            <th style="width: 120px;">Đơn vị</th>
                            <th class="text-center" style="width: 200px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="productTableBody">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@item.MaSP</td>
                                <td>
                                    <div class="fw-bold text-dark product-name">@item.TenSP</div>
                                </td>
                                <td class="text-danger fw-bold">@item.GiaBan.ToString("N0") đ</td>
                                <td>
                                    @if (item.SoLuongTon <= 0)
                                    {
                                        <span class="badge bg-danger shadow-sm py-2 px-3 w-100">
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i> Hết hàng (@item.SoLuongTon)
                                        </span>
                                    }
                                    else if (item.SoLuongTon < 10)
                                    {
                                        <span class="badge bg-warning text-dark shadow-sm py-2 px-3 w-100">
                                            <i class="bi bi-hourglass-split me-1"></i> Sắp hết (@item.SoLuongTon)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success shadow-sm py-2 px-3 w-100">
                                            <i class="bi bi-check2-all me-1"></i> Còn hàng (@item.SoLuongTon)
                                        </span>
                                    }
                                </td>
                                <td><span class="text-muted">@item.DonViTinh</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.MaSP"
                                               class="btn btn-sm btn-outline-warning px-3" title="Sửa">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>

                                        <form asp-action="Delete" asp-route-id="@item.MaSP" method="post"
                                              onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3" title="Xóa">
                                                <i class="bi bi-trash"></i> Xóa
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById('productSearchInput');
        const tableBody = document.getElementById('productTableBody');
        const rows = tableBody.getElementsByTagName('tr');

        searchInput.addEventListener('input', function () {
            const filter = searchInput.value.toLowerCase().trim();

            for (let i = 0; i < rows.length; i++) {
                // Lấy nội dung Mã SP và Tên SP để tìm kiếm
                const maSP = rows[i].getElementsByTagName('td')[0].innerText.toLowerCase();
                const tenSP = rows[i].querySelector('.product-name').innerText.toLowerCase();

                if (maSP.includes(filter) || tenSP.includes(filter)) {
                    rows[i].style.display = "";
                } else {
                    rows[i].style.display = "none";
                }
            }
        });
    });
</script>