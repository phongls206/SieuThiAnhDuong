<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5><i class="bi bi-search"></i> Tra cứu thông tin mặt hàng</h5>
    </div>
    <div class="card-body">
        <form asp-action="Search" method="get" class="row g-3">
            <div class="col-md-9">
                <input type="text" name="query" class="form-control" placeholder="Nhập tên sản phẩm hoặc mã sản phẩm...">
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-success w-100">Tìm kiếm</button>
            </div>
        </form>
        
        <hr />
        <table class="table table-hover mt-3">
            <thead>
                <tr>
                    <th>Mã SP</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá niêm yết</th>
                    <th>Đơn vị tính</th>
                    <th>Tình trạng</th>
                </tr>
            </thead>
            <tbody id="searchResult">
            </tbody>
        </table>
    </div>
</div>