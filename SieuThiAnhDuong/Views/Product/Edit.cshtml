@model SieuThiAnhDuong.Models.SanPham

<div class="container mt-4">
    <div class="card shadow-sm border-0 col-md-8 mx-auto">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>CẬP NHẬT MẶT HÀNG</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                
                <input type="hidden" asp-for="MaSP" />

                <div asp-validation-summary="All" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    <input asp-for="TenSP" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                    <span asp-validation-for="TenSP" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá bán (đ)</label>
                       
                        <input asp-for="GiaBan" type="number" min="0" class="form-control" placeholder="0" required />
                        <span asp-validation-for="GiaBan" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Số lượng tồn kho</label>
                        
                        <input asp-for="SoLuongTon" type="number" min="0" class="form-control" placeholder="0" required />
                        <span asp-validation-for="SoLuongTon" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Đơn vị tính</label>
                 
                    <input asp-for="DonViTinh" class="form-control" placeholder="Ví dụ: Cái, Gói, Chai..." />
                    <span asp-validation-for="DonViTinh" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-circle me-1"></i> Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">
                        <i class="bi bi-save me-1"></i> Lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}